void mqtt_callback(char* topic, byte* payload, unsigned int length) {
  Serial.print("Pesan diterima [");
  Serial.print(topic);
  Serial.print("] ");
  
  String sTopic = String(topic);

  if (sTopic.equals(topicSensorDataSub)) {
     StaticJsonDocument<256> doc;
     DeserializationError error = deserializeJson(doc, payload, length);

     if (!error) {
        float t = doc["suhu"];
        float h = doc["kelembaban"];

        if (t > -900.0) { 
            temp_diterima = t;
            hum_diterima = h;
            
            lastPacketTime = millis(); 
            isConnected = true; 
            
            Serial.printf("[MQTT BRIDGE] Data Masuk: %.2f C, %.2f %%\n", temp_diterima, hum_diterima);
            
            forceLcdClear = true; 
        } else {
            Serial.println("[MQTT BRIDGE] Terima data error dari sensor");
        }
     } else {
        Serial.println("[MQTT BRIDGE] Gagal parse JSON sensor");
     }
     return;
  }

  if (sTopic.equals(topicClimateModeSet)) {
    StaticJsonDocument<100> doc;
    deserializeJson(doc, payload, length);
    const char* newMode = doc["mode"];

    if (newMode) {
      if (strcmp(newMode, "auto") == 0 || strcmp(newMode, "manual") == 0) {
        controlMode = String(newMode);
        Serial.println("Mode Kontrol diatur ke: " + controlMode);
        triggerLcdNotification("Mode Diubah:", "Mode " + controlMode);

        preferences.begin("climate-app", false);
        preferences.putString("ctrlMode", controlMode);
        preferences.end();
        Serial.println("Mode baru disimpan ke Preferences.");
        if (controlMode == "manual") {
            Serial.println("Mode Manual: Mereset timer jadwal & mematikan kipas.");
            kipas1_on_by_schedule = false;
            kipas2_on_by_schedule = false;
            kipas1_stopTime = 0;
            kipas2_stopTime = 0;
            setKipasState(1, false);
            setKipasState(2, false);
        }
      }
    }
  }

  else if (sTopic.equals(topicClimateManualSet)) {
    if (controlMode != "manual") {
      Serial.println("Perintah manual ditolak, mode bukan 'manual'");
      return; 
    }
    StaticJsonDocument<100> doc;
    deserializeJson(doc, payload, length);
    const char* target = doc["target"]; 
    const char* stateStr = doc["state"]; 
    
    Serial.printf("Perintah manual: %s -> %s\n", target, stateStr);
    bool state = (strcmp(stateStr, "ON") == 0);

    if (strcmp(target, "fan1") == 0) {
      kipas1_on_by_schedule = false; 
      kipas1_stopTime = 0;
      setKipasState(1, state);
    } else if (strcmp(target, "fan2") == 0) {
      kipas2_on_by_schedule = false; 
      kipas2_stopTime = 0;
      setKipasState(2, state);
    }
  }
  
  else if (sTopic.equals(topicClimateSettingsSet)) {
    StaticJsonDocument<200> doc;
    deserializeJson(doc, payload, length);
    
    climateSettings.kipas1_min = doc["kipas1_min"] | climateSettings.kipas1_min;
    climateSettings.kipas1_max = doc["kipas1_max"] | climateSettings.kipas1_max;
    climateSettings.kipas2_min = doc["kipas2_min"] | climateSettings.kipas2_min;
    climateSettings.kipas2_max = doc["kipas2_max"] | climateSettings.kipas2_max;
    
    Serial.println("Pengaturan Treshold Climate diperbarui.");

    preferences.begin("climate-app", false);
    preferences.putFloat("k1_min", climateSettings.kipas1_min);
    preferences.putFloat("k1_max", climateSettings.kipas1_max);
    preferences.putFloat("k2_min", climateSettings.kipas2_min);
    preferences.putFloat("k2_max", climateSettings.kipas2_max);
    preferences.end();
    Serial.println("Treshold baru disimpan ke Preferences.");

    char buf[17];
    snprintf(buf, 17, "K1:%.0f-%.0f K2:%.0f-%.0f",
             climateSettings.kipas1_min, climateSettings.kipas1_max,
             climateSettings.kipas2_min, climateSettings.kipas2_max);
    triggerLcdNotification("Set Point Baru:", buf);
  }
  
  else if (sTopic.equals(topicClimateJadwalSet)) {
    StaticJsonDocument<1024> doc; 
    deserializeJson(doc, payload, length);
    
    const char* action = doc["action"];
    Serial.printf("Perintah Jadwal: %s\n", action);

    if (strcmp(action, "REPLACE_ALL") == 0) {
      climateScheduleCount = 0; 
      JsonArray schedules = doc["schedules"].as<JsonArray>();
      for (JsonObject s : schedules) {
        parseAndAddSchedule(s);
      }
      triggerLcdNotification("Jadwal Di-Sync", "Semua diperbarui");
    } else if (strcmp(action, "UPSERT") == 0) {
      parseAndAddSchedule(doc["schedule"].as<JsonObject>());
      triggerLcdNotification("Jadwal Disimpan", "ID: " + String(doc["schedule"]["id"].as<int>()));
    } else if (strcmp(action, "DELETE") == 0) {
      deleteClimateSchedule(doc["scheduleId"].as<int>());
      triggerLcdNotification("Jadwal Dihapus", "ID: " + String(doc["scheduleId"].as<int>()));
    }
  }
  
}

