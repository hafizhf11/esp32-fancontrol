void setKipasState(int kipasNum, bool state) {
  unsigned long now = millis(); 

  if (kipasNum == 1) {
    if (kipas1_State == state) return; 
    if (now - kipas1_lastChangeTime < stableTime) {
      Serial.println("Kipas 1: Perintah ditolak (stable time aktif)");
      return; 
    }
    kipas1_lastChangeTime = now; 
    kipas1_State = state; 
    digitalWrite(KIPAS_1_PIN, state ? HIGH : LOW); 

  } else if (kipasNum == 2) {
    if (kipas2_State == state) return; 
    if (now - kipas2_lastChangeTime < stableTime) {
      Serial.println("Kipas 2: Perintah ditolak (stable time aktif)");
      return; 
    }
    kipas2_lastChangeTime = now; 
    kipas2_State = state; 
    digitalWrite(KIPAS_2_PIN, state ? HIGH : LOW); 
  } else {
    return; 
  }

  if (client.connected()) {
    StaticJsonDocument<50> doc;
    String kipasKey = (kipasNum == 1) ? "kipas1" : "kipas2";
    String stateStr = state ? "ON" : "OFF";
    doc[kipasKey] = stateStr;
    
    char jsonBuffer[50];
    serializeJson(doc, jsonBuffer);
    client.publish(topicClimateStatusSet.c_str(), jsonBuffer, true); 
    Serial.printf("Kipas %d diatur %s (JSON dikirim)\n", kipasNum, stateStr.c_str());
  } else {
    Serial.printf("Kipas %d diatur %s (Offline)\n", kipasNum, state ? "ON" : "OFF");
  }

  forceLcdClear = true; 
}

void checkThresholds() {
  if (temp_diterima == 0.0) return; 

  if (!kipas1_on_by_schedule) {
    if (temp_diterima >= climateSettings.kipas1_max) {
      setKipasState(1, true);
    } else if (temp_diterima <= climateSettings.kipas1_min) {
      setKipasState(1, false);
    }
  }

  if (!kipas2_on_by_schedule) {
    if (temp_diterima >= climateSettings.kipas2_max) {
      setKipasState(2, true);
    } else if (temp_diterima <= climateSettings.kipas2_min) {
      setKipasState(2, false);
    }
  }
}

