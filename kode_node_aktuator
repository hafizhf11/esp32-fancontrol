void checkSchedules() {
  unsigned long now = millis();
  if (now - lastScheduleCheck < 60000) {
    return;
  }
  lastScheduleCheck = now;

  RtcDateTime rtcNow = Rtc.GetDateTime();
  if (!rtcNow.IsValid() || rtcNow.Year() < 2025) {
     Serial.println("Waktu RTC tidak valid, membatalkan cek jadwal.");
     return;
  }

  String currentDate = getFormattedDate(rtcNow);
  String currentTime = getFormattedTime(rtcNow);
  Serial.printf("Mengecek jadwal untuk %s %s\n", currentDate.c_str(), currentTime.c_str());

  for (int i = 0; i < climateScheduleCount; i++) {
    ClimateSchedule& sched = climateSchedules[i];
    if (currentDate.compareTo(sched.tanggalMulai) >= 0 && currentDate.compareTo(sched.tanggalSelesai) <= 0) {
      for (int j = 0; j < sched.waktuCount; j++) {
        if (currentTime.equals(sched.waktu[j])) {
          Serial.printf("MEMICU JADWAL ID %d!\n", sched.id);
          unsigned long stopTime = millis() + (sched.durasi * 60000UL); 

          String fansStr = "";
          if (sched.fans[1]) fansStr += "K1 ";
          if (sched.fans[2]) fansStr += "K2";
          if (fansStr == "") fansStr = "Tidak ada";
          triggerLcdNotification("Jadwal Aktif:", fansStr);

          if (sched.fans[1]) {
            kipas1_on_by_schedule = true;
            kipas1_stopTime = stopTime;
            setKipasState(1, true);
          }
          if (sched.fans[2]) {
            kipas2_on_by_schedule = true;
            kipas2_stopTime = stopTime;
            setKipasState(2, true);
          }
        }
      }
    }
  }
}

void deleteClimateSchedule(int id) {
  int foundIndex = -1;
  for (int i = 0; i < climateScheduleCount; i++) {
    if (climateSchedules[i].id == id) {
      foundIndex = i;
      break;
    }
  }

  if (foundIndex != -1) {
    Serial.printf("Menghapus jadwal ID %d\n", id);
    for (int i = foundIndex; i < climateScheduleCount - 1; i++) {
      climateSchedules[i] = climateSchedules[i + 1];
    }
    climateScheduleCount--;
  }
}

void parseAndAddSchedule(JsonObject s) {
  int id = s["id"];
  int slot = -1;

  for (int i = 0; i < climateScheduleCount; i++) {
    if (climateSchedules[i].id == id) {
      slot = i;
      break;
    }
  }

  if (slot == -1) {
    if (climateScheduleCount >= MAX_CLIMATE_SCHEDULES) {
      Serial.println("Kapasitas jadwal penuh!");
      return;
    }
    slot = climateScheduleCount; 
    climateScheduleCount++;
  }

  Serial.printf("Menyimpan jadwal ID %d di slot %d\n", id, slot);
  ClimateSchedule& sched = climateSchedules[slot];
  sched.id = id;
  sched.durasi = s["durasi"] | 0;

  strlcpy(sched.tanggalMulai, s["tanggalMulai"] | "2025-01-01", 11);
  strlcpy(sched.tanggalSelesai, s["tanggalSelesai"] | "2099-12-31", 11);

  JsonArray waktuArray = s["waktu"].as<JsonArray>();
  sched.waktuCount = 0;
  for (JsonVariant v : waktuArray) {
    if (sched.waktuCount < MAX_WAKTU_PER_SCHEDULE) {
      strlcpy(sched.waktu[sched.waktuCount], v.as<const char*>(), 6);
      sched.waktuCount++;
    }
  }

  sched.fans[1] = false;
  sched.fans[2] = false;
  JsonArray fansArray = s["fans"].as<JsonArray>();
  for (JsonVariant v : fansArray) {
    int fanNum = v.as<int>();
    if (fanNum == 1) sched.fans[1] = true;
    if (fanNum == 2) sched.fans[2] = true;
  }
}

