String getFormattedDate(const RtcDateTime& dt) {
  char buf[11];
  snprintf(buf, sizeof(buf), "%04u-%02u-%02u", dt.Year(), dt.Month(), dt.Day());
  return String(buf);
}

String getFormattedTime(const RtcDateTime& dt) {
  char buf[6];
  snprintf(buf, sizeof(buf), "%02u:%02u", dt.Hour(), dt.Minute());
  return String(buf);
}


