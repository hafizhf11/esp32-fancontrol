void setup() {
  Serial.begin(115200);
  Serial.println("\n--- [ESP32 CLIMATE CONTROL] ---");
  Wire.begin(32, 33); 
  lcd.init();
  lcd.backlight();
  lcd.print("Inisialisasi...");
  delay(1000);
  loadSettingsFromPreferences();

  Serial.println("Mulai RTC DS1302...");
  lcd.clear(); lcd.print("Init RTC...");
  Rtc.Begin();

  pinMode(KIPAS_1_PIN, OUTPUT);
  pinMode(KIPAS_2_PIN, OUTPUT);
  digitalWrite(KIPAS_1_PIN, LOW); 
  digitalWrite(KIPAS_2_PIN, LOW); 
  Serial.println("Pin Kipas disetup (OFF).");

  WiFi.mode(WIFI_STA);
  
  Serial.printf("Menghubungkan ke %s... ", ssid); 
  lcd.clear(); lcd.print("Connecting WiFi...");
  WiFi.begin(ssid, password);
  
  unsigned long wifiStartTime = millis();
  while (WiFi.status() != WL_CONNECTED && (millis() - wifiStartTime < 15000)) {
     delay(500); 
     Serial.print("."); 
     lcd.print(".");
  }

  if (WiFi.status() == WL_CONNECTED) {
     Serial.println(" Terhubung!");
     int actualChannel = WiFi.channel();
     Serial.printf("===== Channel Asli WiFi: %d =====\n", actualChannel);
     
     Serial.println("WiFi terhubung, memaksa sinkronisasi NTP...");
     syncRtcWithNtp();

  } else {
     Serial.println(" Gagal terhubung WiFi (Timeout). Lanjut mode offline.");
     lcd.clear(); lcd.print("WiFi Gagal. Offline.");
     delay(1000);
  }
  
  if (WiFi.status() != WL_CONNECTED && controlMode == "manual") {
    Serial.println("Booting Offline dalam mode Manual. Memaksa kembali ke AUTO.");
    controlMode = "auto";
    preferences.begin("climate-app", false);
    preferences.putString("ctrlMode", "auto");
    preferences.end();
    triggerLcdNotification("Mode Offline", "Otomatis Aktif", 3000);
  }


  Serial.println("Inisialisasi ESP-NOW (Penerima)...");
  if (esp_now_init() != ESP_OK) {
    Serial.println("Error inisialisasi ESP-NOW");
    return;
  }
  esp_now_register_recv_cb(OnDataRecv);

  byte macBytes[6];
  WiFi.macAddress(macBytes);
  char macStr[18];
  snprintf(macStr, sizeof(macStr), "%02X-%02X-%02X-%02X-%02X-%02X",
           macBytes[0], macBytes[1], macBytes[2], macBytes[3], macBytes[4], macBytes[5]);
  macAddress = String(macStr);
  Serial.print("MAC Address: "); Serial.println(macAddress);

  topicPrefix = "ezramnd/climate/esp32/alat/" + macAddress;
  topicClimateJadwalSet = topicPrefix + "/climate-jadwal/set";
  topicClimateSettingsSet = topicPrefix + "/climate-settings/set";
  topicClimateManualSet = topicPrefix + "/climate-manual/set";
  topicClimateStatusSet = topicPrefix + "/status";
  topicClimateModeSet = topicPrefix + "/climate-mode/set";
  topicClimateJadwalGet = topicPrefix + "/climate-jadwal/get";
  Serial.println("Topik dinamis dibuat.");

  espClient.setInsecure(); 
  client.setBufferSize(1024);
  client.setServer(mqtt_server, mqtt_port);
  client.setCallback(mqtt_callback); 

  lastPacketTime = millis(); 
  isConnected = false;      

  lcd.clear();
  lcd.print("Menunggu data...");
  Serial.println("--- [SETUP SELESAI] ---");
}

void loop() {
  
  if (WiFi.status() != WL_CONNECTED) {
    unsigned long now = millis();
    if (now - lastWifiReconnectAttempt > wifiReconnectInterval) {
      Serial.println("WiFi terputus. Mencoba koneksi ulang...");
      WiFi.begin(ssid, password);
      lastWifiReconnectAttempt = now;
    }
  } else {
    client.loop(); 
    if (!client.connected()) {
      reconnectMQTT(); 
    }
    if (millis() - lastNtpSync > ntpSyncInterval) {
      syncRtcWithNtp();
    }
  }

  if (controlMode == "auto") {
      checkScheduleTimers(); 
      checkSchedules();       
  }
  
  if ( (millis() - lastPacketTime > timeoutDuration) && (isConnected == true) ) {
    Serial.println("Koneksi sensor terputus! (Timeout)");
    isConnected = false;
    forceLcdClear = true; 
    
    if (!kipas1_on_by_schedule) setKipasState(1, false);
    if (!kipas2_on_by_schedule) setKipasState(2, false);
  }

  if (isConnected && temp_diterima != 0.0) { 
    if (controlMode == "auto") {
      checkThresholds(); 
    }
  }

  if (millis() - lastLcdUpdateTime > lcdUpdateInterval) {
    lastLcdUpdateTime = millis(); 
    
    if (isNotifActive) {
      if (millis() < notifEndTime) {
        if (forceLcdClear) {
            lcd.clear();
            forceLcdClear = false;
            lcd.setCursor(0, 1); lcd.print(notifLine1);
            lcd.setCursor(0, 2); lcd.print(notifLine2);
        }
      } else {
        isNotifActive = false; forceLcdClear = true; screenChangeCounter = 0; displayMode = 0;
      }
    } 
    else
    {
      screenChangeCounter++; 
      if (screenChangeCounter >= screenChangeInterval) {
        displayMode = (displayMode + 1) % 2; 
        screenChangeCounter = 0; 
        forceLcdClear = true; 
      }

      if (forceLcdClear) {
        lcd.clear();
        forceLcdClear = false;
      }
      
      char buf[21]; 
      switch (displayMode) {
        case 0:
        {
            if (isConnected) {
               snprintf(buf, 21, "Suhu:       %6.2f C", temp_diterima);
            } else {
               snprintf(buf, 21, "Suhu:       --.--  C");
            }
            lcd.setCursor(0, 0); lcd.print(buf);

            if (isConnected) {
               snprintf(buf, 21, "Kelembaban: %6.2f %%", hum_diterima);
            } else {
               snprintf(buf, 21, "Kelembaban: --.-- %%");
            }
            lcd.setCursor(0, 1); lcd.print(buf);
            
            String statusK1;
            if (controlMode == "manual") { statusK1 = kipas1_State ? "ON (Manual)" : "OFF (Manual)"; }
            else if (kipas1_on_by_schedule) { statusK1 = "ON (JADWAL)"; }
            else { statusK1 = kipas1_State ? "ON (Suhu)" : "OFF (Suhu)"; }
            snprintf(buf, 21, "Kipas 1: %-12s", statusK1.c_str());
            lcd.setCursor(0, 2); lcd.print(buf);

            String statusK2;
            if (controlMode == "manual") { statusK2 = kipas2_State ? "ON (Manual)" : "OFF (Manual)"; }
            else if (kipas2_on_by_schedule) { statusK2 = "ON (JADWAL)"; }
            else { statusK2 = kipas2_State ? "ON (Suhu)" : "OFF (Suhu)"; }
            snprintf(buf, 21, "Kipas 2: %-12s", statusK2.c_str());
            lcd.setCursor(0, 3); lcd.print(buf);
            break;
        }
        case 1:
        { 
            RtcDateTime now = Rtc.GetDateTime(); 
            snprintf(buf, 21, "%02u/%02u/%04u  %02u:%02u:%02u", 
                          now.Day(), now.Month(), now.Year(), 
                          now.Hour(), now.Minute(), now.Second());
            lcd.setCursor(0, 0); lcd.print(buf);
            
            String statusOnline = "OFFLINE"; 
            if (WiFi.status() == WL_CONNECTED) {
              statusOnline = client.connected() ? "ONLINE" : "NO-MQTT";
            }
            snprintf(buf, 21, "Mode: %-7s %-7s", controlMode.c_str(), statusOnline.c_str());
            lcd.setCursor(0, 1); lcd.print(buf);

            snprintf(buf, 21, "K1 Set: %.1f - %.1f C", climateSettings.kipas1_min, climateSettings.kipas1_max);
            lcd.setCursor(0, 2); lcd.print(buf);
            snprintf(buf, 21, "K2 Set: %.1f - %.1f C", climateSettings.kipas2_min, climateSettings.kipas2_max);
            lcd.setCursor(0, 3); lcd.print(buf);
            break; 
        } 
      }
    }
  }

  if (WiFi.status() == WL_CONNECTED && client.connected() && temp_diterima != 0.0) {
    
    unsigned long now = millis();
    if (now - lastDataPublish > dataPublishInterval) {
      lastDataPublish = now;

      StaticJsonDocument<256> doc; 
      
      doc["suhu"] = temp_diterima;
      doc["kelembaban"] = hum_diterima;

      doc["kipas1"] = kipas1_State ? "ON" : "OFF";
      doc["kipas2"] = kipas2_State ? "ON" : "OFF";

      char jsonBuffer[256];
      serializeJson(doc, jsonBuffer);

      String dataTopic = topicPrefix + "/data";
      
      if (client.publish(dataTopic.c_str(), jsonBuffer)) {
        Serial.print(">> [MQTT] Data Lengkap Terkirim: ");
        Serial.println(jsonBuffer);
      } else {
        Serial.println(">> [MQTT] Gagal Publish Data");
      }
    }
  } 
  
}
